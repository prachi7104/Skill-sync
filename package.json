    "test-rls": "npx tsx scripts/test-rls.ts",
    "rls:setup": "npx tsx scripts/apply-rls.ts && npx tsx scripts/verify-rls.ts",
    "rls:check": "npx tsx scripts/verify-rls.ts",
    "rls:test": "npx tsx scripts/test-rls.ts"
  },
