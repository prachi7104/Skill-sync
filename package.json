{
  "name": "skillsync",
  "version": "0.1.0",
  "engines": {
    "node": "20.x"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "drizzle:generate": "echo 'Use DRIZZLE_MIGRATIONS_ENABLED=true npx drizzle-kit generate locally only'",
    "drizzle:push": "echo 'BLOCKED: Apply schema changes manually via Supabase SQL Editor'",
    "db:index": "npx tsx scripts/apply-indexes.ts",
    "db:analyze": "npx tsx scripts/analyze-queries.ts",
    "seed:jds": "npx tsx scripts/seed-sample-jds.ts",
    "apply-rls": "npx tsx scripts/apply-rls.ts",
    "verify-rls": "npx tsx scripts/verify-rls.ts",
    "test-rls": "npx tsx scripts/test-rls.ts",
    "rls:setup": "npx tsx scripts/apply-rls.ts && npx tsx scripts/verify-rls.ts",
    "rls:check": "npx tsx scripts/verify-rls.ts",
    "rls:test": "npx tsx scripts/test-rls.ts",
    "ranking:run": "npx tsx scripts/run-ranking.ts",
    "preflight": "node scripts/preflight.js",
    "dev:safe": "node scripts/preflight.js && next dev",
    "clean": "rimraf .next",
    "nuke": "rimraf .next node_modules && npm install",
    "rebuild": "rimraf .next node_modules && npm install && node scripts/preflight.js && next dev",
    "validate:pilot": "npx tsx scripts/validate-pilot.ts"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@google/generative-ai": "^0.24.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/supabase-js": "^2.38.4",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.37.0",
    "lucide-react": "^0.368.0",
    "mammoth": "^1.11.0",
    "nanoid": "^4.0.2",
    "next": "^14.1.0",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "p-limit": "3.1.0",
    "pdf-parse": "^1.1.1",
    "postgres": "^3.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.17",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.8",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.1.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
