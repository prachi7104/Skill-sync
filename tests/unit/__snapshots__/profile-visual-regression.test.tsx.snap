exports[`Profile visual regression snapshots > matches tab nav active states 1`] = `
<div
  aria-label="Profile sections"
  class="grid grid-cols-4 items-stretch border-b border-border"
  role="tablist"
>
  <button
    aria-controls="profile-tabpanel-identity"
    aria-selected="true"
    class="relative flex min-w-0 flex-col items-center justify-center gap-1 px-2 py-2.5 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-card sm:flex-row sm:gap-2 sm:px-4 sm:py-3 sm:text-sm text-foreground"
    id="profile-tab-identity"
    role="tab"
    tabindex="0"
    type="button"
  >
    <svg
      class="lucide lucide-user shrink-0"
      fill="none"
      height="14"
      stroke="currentColor"
