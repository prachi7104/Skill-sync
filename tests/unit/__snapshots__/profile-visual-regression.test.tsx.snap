    >
      Skills
    </span>
  </button>
  <button
    aria-controls="profile-tabpanel-projects"
    aria-selected="false"
    class="relative flex min-w-0 flex-col items-center justify-center gap-1 px-2 py-2.5 text-xs font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-card sm:flex-row sm:gap-2 sm:px-4 sm:py-3 sm:text-sm text-muted-foreground hover:text-foreground"
    id="profile-tab-projects"
    role="tab"
    tabindex="-1"
    type="button"
  >
    <svg
      class="lucide lucide-folder-open shrink-0"
      fill="none"
      height="14"
      stroke="currentColor"
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      viewBox="0 0 24 24"
      width="14"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="m6 14 1.5-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.54 6a2 2 0 0 1-1.95 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.69.9l.81 1.2a2 2 0 0 0 1.67.9H18a2 2 0 0 1 2 2v2"
